    "data": {
      "名称": "战争法师",
      "原文": "WAR WIZARD",
      "位阶": "2",
      "种类": "远程",
      "特性": [
        {
          "名称": "战斗传送",
          "原名": "Battle Teleport",
          "类型": "被动",
          "特性描述": "在进行普通攻击之前或之后，你可以**标记 1 压力点**以传送到远距离范围内的一个位置。"
        },
        {
          "名称": "刷新防护球",
          "原名": "Refresh Warding Sphere",
          "类型": "动作",
          "特性描述": "**标记 1 压力点**以刷新战争法师的“防护球”反应。"
        },
        {
          "名称": "地壳喷发",
          "原名": "Eruption",
          "类型": "动作",
          "特性描述": "**花费 1 恐惧点**并选择远距离范围内的一个点。该点周围的邻近范围区域会喷发，变成不可逾越的地形。该区域内的所有目标必须进行一次敏捷反应掷骰（14）。失败的目标受到2d10物理伤害并被抛出该区域。成功的目标受到一半伤害且不会被移动。"
        },
        {
          "名称": "奥术炮击",
          "原名": "Arcane Artillery",
          "类型": "动作",
          "特性描述": "**花费 1 恐惧点**以释放精确的魔法弹幕。场景中的所有目标必须进行一次敏捷反应掷骰。失败的目标受到2d12魔法伤害。成功的目标受到一半伤害。"
        },
        {
          "名称": "防护球",
          "原名": "Warding Sphere",
          "类型": "反应",
          "特性描述": "当战争法师受到近距离范围内的攻击伤害时，对攻击者造成2d6魔法伤害。该反应在法师使用其“刷新防护球”动作刷新前无法再次使用。"
        }
      ],
      "类型": "敌人",
      "简介": "一名精通破坏魔法、久经沙场的法师。",
      "动机与战术": "研发新法术，追求力量，打破阵型",
